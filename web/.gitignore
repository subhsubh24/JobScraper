# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# playwright e2e artifacts (generated; CI uploads them — not committed)
/test-results/
/playwright-report/
/.last-run.json
# The dual-axis visual-verification baseline (ROADMAP Track E) is intentionally COMMITTED
# (judged on a vision model + gated by scripts/preflight.sh). Scope the un-ignore to the
# PNGs ONLY so a failing local run can never leak stray artifacts (traces, error-context.md,
# partial junk) into a commit — only the named page screenshots are trackable.
/e2e/__screenshots__/*
!/e2e/__screenshots__/*.png
