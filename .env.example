# Career Operator Environment Variables
# Copy this to .env and fill in your values

# Required: OpenAI API Key for AI features
OPENAI_API_KEY=sk-your-openai-api-key-here

# Database URL
# SQLite for local development:
DATABASE_URL=sqlite:///data/jobscraper.db
# PRODUCTION (Vercel serverless): SQLite does NOT persist — use Supabase Postgres.
# Use the SUPABASE TRANSACTION POOLER (Supavisor, port 6543) — it's IPv4-only and
# built for many short-lived serverless connections. NOT the direct 5432 connection
# (IPv6) and NOT the session pooler. Username embeds your project ref. Add sslmode.
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-[REGION].pooler.supabase.com:6543/postgres?sslmode=require
# (We use psycopg2 + NullPool, which is compatible with transaction-mode pooling —
#  psycopg2 doesn't use persistent prepared statements, so no extra config needed.)

# JWT Secret for authentication (generate a secure random string: openssl rand -hex 32)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# CORS: comma-separated allowed origins (mobile/web clients). Lock this down in prod.
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://yourdomain.com

# Per-user/day ceiling on expensive LLM calls (wallet-drain defense)
LLM_DAILY_CEILING=25

# Optional: Enable SQL query logging
SQL_DEBUG=false

# Optional: local/container server port (Vercel ignores this)
PORT=8000

# Optional: Stripe for web payments (Track C)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Set automatically by Vercel at runtime (do not set yourself): VERCEL=1
