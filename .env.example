# Career Operator — environment variables
# Copy this to .env and fill in your values. Everything the app reads is listed here; anything
# commented out is OPTIONAL (the app degrades gracefully without it). Secrets are NEVER committed
# — this file only shows shapes/placeholders. Full validation contract: docs/ci/VALIDATION.md.

# ─────────────────────────────────────────────────────────────────────────────
# Core
# ─────────────────────────────────────────────────────────────────────────────

# Database URL.
# SQLite for local development:
DATABASE_URL=sqlite:///data/jobscraper.db
# PRODUCTION (Vercel serverless): SQLite does NOT persist — use Neon Postgres.
# Use the NEON POOLED connection (host has `-pooler`) — built for many short-lived
# serverless connections. NOT the direct (unpooled) host. Add sslmode=require.
# DATABASE_URL=postgresql://[USER]:[PASSWORD]@ep-[ID]-pooler.[REGION].aws.neon.tech/[DB]?sslmode=require
# (We use psycopg2 + NullPool — compatible with PgBouncer; we don't use SQL-level
#  PREPARE/EXECUTE, so no extra config needed.)

# JWT secret for authentication (generate a secure random string: openssl rand -hex 32).
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Optional: create missing tables on boot (dev convenience). Prod applies Alembic migrations
# instead — leave OFF (0) in production. Only ever CREATES missing tables, never alters columns.
# AUTO_CREATE_TABLES=0

# Optional: local/container server port (Vercel ignores this).
PORT=8000

# Optional: SQL query logging (dev).
SQL_DEBUG=false

# Optional: structured logging. LOG_LEVEL: DEBUG|INFO|WARNING|ERROR (default INFO).
# LOG_FORMAT: JSON structured logs are the DEFAULT (when unset) — good for prod log ingestion.
# Set LOG_FORMAT=plain for human-readable logs (typically local dev).
# LOG_LEVEL=INFO
# LOG_FORMAT=plain

# ─────────────────────────────────────────────────────────────────────────────
# AI (Google Gemini) — optional; app degrades to heuristics without a key
# ─────────────────────────────────────────────────────────────────────────────

# Google Gemini API key (used via Gemini's OpenAI-compatible endpoint).
GEMINI_API_KEY=your-gemini-api-key-here
# Optional model overrides (defaults: gemini-flash-latest / gemini-embedding-001).
# The default primary is the floating alias 'gemini-flash-latest' — it rolls forward to the
# current GA flash model and CAN'T be version-decommissioned the way a pinned 'gemini-X.Y-flash'
# can (Google 404'd gemini-2.0-flash, then gemini-2.5-flash). Only pin GEMINI_MODEL if you need a
# specific version; the app still auto-falls-back on a model-not-found 404.
# GEMINI_MODEL=gemini-flash-latest
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# Optional: override the auto-fallback chain (comma-separated), tried on a model-not-found 404.
# GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite
# Optional: per-external-call timeout in seconds (MUST stay < the serverless function budget so a
# hung LLM call fails loud in-request rather than being killed by the platform). Default 45.
# LLM_TIMEOUT_SECONDS=45
# Per-user/day ceilings (wallet-drain defense). LLM_DAILY_CEILING bounds expensive LLM
# generations; SCORE_DAILY_CEILING bounds embedding-based job scoring.
LLM_DAILY_CEILING=25
# SCORE_DAILY_CEILING=100
# Optional: the drafter→reviewer refinement pass on generated artifacts (default ON). Set to 0 to
# disable (halves Gemini calls per generation at some quality cost) — owner kill-switch.
# ENABLE_ARTIFACT_REFINEMENT=1

# ─────────────────────────────────────────────────────────────────────────────
# Security / auth / CORS
# ─────────────────────────────────────────────────────────────────────────────

# CORS: comma-separated allowed origins (web clients). Locked down in prod; native mobile uses
# bearer tokens (no CORS). Leave unset in prod → same-origin web + native both still work.
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://yourdomain.com

# Public base URL of the web app — used to build absolute links (e.g. the waitlist confirm link
# in email). Set in prod so generated links point at the real domain.
# WEB_APP_URL=https://your-app.vercel.app

# Cloudflare Turnstile bot protection on public forms (Track F). The seam is a no-op until
# TURNSTILE_SECRET is set (server verifies the token). The web widget renders only when
# NEXT_PUBLIC_TURNSTILE_SITEKEY (the PUBLIC site key — safe in the client bundle) is set at build
# time. Set BOTH together at launch (and only after a native mobile widget ships — otherwise
# native auth 403s); leave unset pre-launch. See docs/ci/VALIDATION.md `captcha`.
# TURNSTILE_SECRET=0x...             # server-side secret — NEVER commit a real one
# NEXT_PUBLIC_TURNSTILE_SITEKEY=0x...  # public site key (web build-time)

# Optional: per-account login lockout tuning (defaults: 5 failures → 900s lockout).
# LOGIN_MAX_FAILURES=5
# LOGIN_LOCKOUT_SECONDS=900

# Optional: trust X-Forwarded-For for the client IP (rate-limit keying). Defaults ON when running
# behind Vercel/Lambda; set explicitly to 1/0 to override. Only enable behind a trusted proxy.
# TRUST_PROXY_HEADERS=1

# TEST-ONLY: disables rate limiting for the E2E journey suite. NEVER set in production (the app
# logs a loud warning and it weakens abuse defense). Left unset here on purpose.
# E2E_DISABLE_RATE_LIMIT=1

# ─────────────────────────────────────────────────────────────────────────────
# Billing — Stripe (web, Track C). Live keys + price IDs are owner-only (PENDING_OPS).
# ─────────────────────────────────────────────────────────────────────────────

# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs per plan (the checkout endpoint refuses honestly with 503 until the relevant one is
# set — no fake success). Create these as recurring Prices in the Stripe dashboard.
# STRIPE_PRICE_PRO_MONTHLY=price_...
# STRIPE_PRICE_PRO_ANNUAL=price_...
# STRIPE_PRICE_CAREERPLUS_MONTHLY=price_...
# STRIPE_PRICE_CAREERPLUS_ANNUAL=price_...
# STRIPE_PRICE_TEAM_ANNUAL=price_...   # team/B2B2C seat tier (quantity-based)

# ─────────────────────────────────────────────────────────────────────────────
# Mobile billing — RevenueCat (Track C). Owner-only; native client is owner-blocked.
# ─────────────────────────────────────────────────────────────────────────────

# Shared secret for the RevenueCat webhook Authorization header (constant-time verified;
# a forged/missing header grants NOTHING, unconfigured refuses honestly with 503).
# REVENUECAT_WEBHOOK_AUTH=your-revenuecat-webhook-shared-secret

# ─────────────────────────────────────────────────────────────────────────────
# Email provider (Track H) — waitlist double-opt-in. Default backend is dry-run (honest:
# no fake "sent"); set SMTP_* to deliver for real. The confirm token reuses JWT_SECRET.
# ─────────────────────────────────────────────────────────────────────────────

# EMAIL_BACKEND=dryrun            # dryrun (default) | capture (tests) | smtp (real)
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_FROM=Career Operator <hello@yourdomain.com>
# SMTP_USERNAME=your-smtp-username
# SMTP_PASSWORD=your-smtp-password
# SMTP_STARTTLS=1
# SMTP_TIMEOUT=10

# ─────────────────────────────────────────────────────────────────────────────
# Analytics (Track H) — privacy-safe aggregate read API (no PII)
# ─────────────────────────────────────────────────────────────────────────────

# Shared secret gating GET /api/analytics/summary (constant-time compare; 503 when unset). The
# record path needs no key; only the opt-in read endpoint requires this.
# ANALYTICS_READ_TOKEN=your-analytics-read-token

# ─────────────────────────────────────────────────────────────────────────────
# Cost telemetry — Margin (cost-per-outcome). Optional, fail-safe, INERT unless BOTH are set:
# the meter never blocks scoring/LLM calls and swallows its own errors. See docs/ci/VALIDATION.md
# `margin`. No product impact when unset — this is observability only.
# ─────────────────────────────────────────────────────────────────────────────

# MARGIN_INGEST_URL=https://ingest.your-margin-instance.com
# MARGIN_INGEST_KEY=your-margin-ingest-key

# Set automatically by the platform at runtime (do NOT set yourself): VERCEL=1,
# AWS_LAMBDA_FUNCTION_NAME=... (used only to detect the serverless environment).
